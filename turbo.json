{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "build:smoke": {
      "dependsOn": ["build"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["^build"]
    },
    "test:watch": {
      "cache": false,
      "persistent": true
    },
    "lint": {},
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "clean": {
      "cache": false
    },
    "@zigrivers/surface-adapter-agnostic#lint": {
      "dependsOn": ["^build"]
    },
    "@zigrivers/surface-adapter-react#lint": {
      "dependsOn": ["^build"]
    },
    "@zigrivers/surface-adapter-svelte#lint": {
      "dependsOn": ["^build"]
    },
    "@zigrivers/surface-adapter-vue#lint": {
      "dependsOn": ["^build"]
    },
    "@zigrivers/surface#lint": {
      "dependsOn": ["^build"]
    },
    "@zigrivers/surface-grounding#lint": {
      "dependsOn": ["^build"]
    },
    "@zigrivers/surface-mcp#lint": {
      "dependsOn": ["^build"]
    }
  }
}
