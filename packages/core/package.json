{
  "name": "@zigrivers/surface-core",
  "version": "0.2.2",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./interfaces": {
      "types": "./dist/interfaces.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@noble/hashes": "catalog:",
    "@octokit/rest": "catalog:",
    "execa": "^9.6.1",
    "gray-matter": "^4.0.3",
    "parse5": "^8.0.1",
    "pino": "catalog:",
    "proper-lockfile": "catalog:",
    "retext": "^9.0.0",
    "retext-english": "^5.0.0",
    "retext-equality": "^7.1.0",
    "retext-readability": "^8.0.0",
    "write-file-atomic": "catalog:",
    "yaml": "catalog:",
    "zod": "catalog:"
  },
  "scripts": {
    "build": "tsup && node ../../scripts/copy-knowledge.mjs dist/content/knowledge",
    "build:smoke": "node scripts/build-smoke.mjs",
    "clean": "rm -rf dist coverage .turbo",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit && tsc -p scripts/tsconfig.json"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/proper-lockfile": "catalog:",
    "@types/write-file-atomic": "catalog:",
    "eslint": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "playwright": "^1.60.0"
  },
  "peerDependenciesMeta": {
    "playwright": {
      "optional": true
    }
  },
  "description": "Core schemas, state, scoring, and orchestration for Surface",
  "license": "MIT",
  "homepage": "https://github.com/zigrivers/surface#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zigrivers/surface.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/zigrivers/surface/issues"
  },
  "keywords": [
    "surface",
    "ui-audit",
    "core",
    "accessibility"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
