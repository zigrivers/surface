{
  "name": "@surface/core",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./interfaces": {
      "types": "./dist/interfaces.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@noble/hashes": "catalog:",
    "@octokit/rest": "catalog:",
    "execa": "^9.6.1",
    "gray-matter": "^4.0.3",
    "pino": "catalog:",
    "proper-lockfile": "catalog:",
    "retext": "^9.0.0",
    "retext-english": "^5.0.0",
    "retext-equality": "^7.1.0",
    "retext-readability": "^8.0.0",
    "write-file-atomic": "catalog:",
    "yaml": "catalog:",
    "zod": "catalog:"
  },
  "scripts": {
    "build": "tsup",
    "build:smoke": "node scripts/build-smoke.mjs",
    "clean": "rm -rf dist coverage .turbo",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit && tsc -p scripts/tsconfig.json"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/proper-lockfile": "catalog:",
    "@types/write-file-atomic": "catalog:",
    "eslint": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "playwright": "^1.60.0"
  },
  "peerDependenciesMeta": {
    "playwright": {
      "optional": true
    }
  }
}
