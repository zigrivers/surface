# surface — example environment file.
# Copy to `.env` (gitignored) and fill in only what you need.
#
# IMPORTANT: every variable here is OPTIONAL. surface runs in *measured-only* mode
# with NO keys configured — it never transmits captured UI to any model or service
# unless you explicitly provide a key below (PRD NFR-DATA-1, BYO-key contract).
#
# Layered model access (docs/tech-stack.md §"model access"):
#   - No key set         -> measured-only (Axe/Lighthouse/static), no judged findings.
#   - One key set        -> judged findings from that provider's SDK.
#   - Multiple keys set  -> multi-model reconciliation across providers.

# --- Judged-findings / model providers (BYO key) ----------------------------
# Anthropic (Claude) — primary judged-findings provider.
ANTHROPIC_API_KEY=

# OpenAI (GPT / Codex) — enables multi-model reconciliation.
OPENAI_API_KEY=

# Google (Gemini) — enables multi-model reconciliation.
GEMINI_API_KEY=

# Default model id used for judged findings when a key is present.
# Leave blank to use surface's built-in default for the configured provider.
SURFACE_MODEL=

# --- Runtime / diagnostics --------------------------------------------------
# pino log level: trace | debug | info | warn | error | fatal  (default: info)
SURFACE_LOG_LEVEL=info

# Set to 1 for verbose internal diagnostics on stderr (mirrors `surface --verbose`).
SURFACE_DEBUG=
