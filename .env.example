# surface — example environment file.
# Copy to `.env` (gitignored) and fill in only what you need.
#
# IMPORTANT: every variable here is OPTIONAL. surface runs in *measured-only* mode
# with NO keys configured — it never transmits captured UI to any model or service
# unless you explicitly opt into model fallback below.
#
# API/local providers are a core BYO integration point for hosts that inject a real
# model adapter. The stock CLI does not call provider SDKs from these keys alone.

# --- Judged-findings / model providers (custom BYO adapter) -----------------
# Keep blank unless your host/plugin injects a real provider adapter.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# Default model id used for judged findings when a key is present.
# Leave blank to use surface's built-in default for the configured provider.
SURFACE_MODEL=

# --- Subscription-backed model fallback (explicit opt-in) -------------------
# off | direct | mmr | auto. Default is off; project config alone is not consent.
SURFACE_MODEL_FALLBACK=off

# Direct subscription CLI channels to try when fallback is direct/auto.
# Built-in direct ids: claude,codex,gemini. Grok/Antigravity require host-injected providers
# or MMR-based review outside direct subscription fallback.
# Built-in direct execution currently requires macOS sandbox-exec isolation.
SURFACE_MODEL_CHANNELS=claude,codex,gemini

# Model fallback/reconciliation depth, 1-5. Default is 3.
SURFACE_MODEL_DEPTH=3

# blocked | redacted-only. redacted-only permits only verified redaction metadata,
# never raw screenshots. It also raises runtime model egress to
# text-and-screenshots unless a harder user/project policy blocks it.
SURFACE_MODEL_SCREENSHOTS=blocked

# --- Runtime / diagnostics --------------------------------------------------
# pino log level: trace | debug | info | warn | error | fatal  (default: info)
SURFACE_LOG_LEVEL=info

# Set to 1 for verbose internal diagnostics on stderr (mirrors `surface --verbose`).
SURFACE_DEBUG=
