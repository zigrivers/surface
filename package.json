{
  "name": "surface-monorepo",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.0.0",
  "engines": {
    "node": ">=22.13.0"
  },
  "license": "MIT",
  "scripts": {
    "dev": "turbo watch build",
    "build": "turbo run build",
    "test": "turbo run test",
    "test:watch": "turbo run test:watch",
    "test:evals": "vitest run tests/evals",
    "test:e2e": "pnpm --filter @surface/cli build && vitest run tests/e2e",
    "benchmark:sc6": "pnpm --filter @surface/cli build && vitest run tests/benchmark",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "pnpm run format:check && turbo run lint typecheck test build:smoke && pnpm run test:e2e && pnpm run benchmark:sc6",
    "clean": "turbo run clean && rm -rf node_modules/.cache .turbo"
  },
  "devDependencies": {
    "@eslint/js": "catalog:",
    "eslint": "catalog:",
    "eslint-config-prettier": "catalog:",
    "eslint-plugin-jsx-a11y": "catalog:",
    "prettier": "catalog:",
    "turbo": "^2.5.0",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:",
    "vitest": "catalog:"
  }
}
